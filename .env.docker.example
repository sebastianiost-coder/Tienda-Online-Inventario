# Copiar a .env.docker en el servidor y cambiar credenciales antes de levantar Docker.

APP_HOST=tiendaonlinemilanesas.tideapps.com
HTTP_PORT=8091
HTTPS_PORT=8451

POSTGRES_DB=tienda_inventario
POSTGRES_USER=tienda_user
POSTGRES_PASSWORD=cambiar_esta_password

NODE_ENV=production
PORT=8088
DATABASE_URL=postgres://tienda_user:cambiar_esta_password@db:5432/tienda_inventario
JWT_SECRET=cambiar_por_un_secreto_largo_unico
CORS_ORIGIN=https://tiendaonlinemilanesas.tideapps.com,https://tiendaonlinemilanesas.tideapps.com:8451,http://tiendaonlinemilanesas.tideapps.com:8091

# El frontend productivo debe llamar a la API a traves del proxy.
VITE_API_URL=/api
